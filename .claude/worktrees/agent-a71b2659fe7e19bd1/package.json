{
	"name": "working-society",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"start": "vite dev",
		"reset": "rm -f working-society.sqlite working-society.sqlite-shm working-society.sqlite-wal && tsx scripts/seed.ts && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "find src -name '*.test.ts' -print0 | xargs -0 tsx --test"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/leaflet": "^1.9.14",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tsx": "^4.22.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@types/bcrypt": "^6.0.0",
		"bcrypt": "^6.0.0",
		"better-sqlite3": "^12.10.0",
		"leaflet": "^1.9.4"
	}
}
